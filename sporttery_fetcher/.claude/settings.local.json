{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(python*)",
      "Bash(pytest*)",
      "Bash(streamlit*)",
      "Bash(scripts\\verify.bat)",
      "Bash(scripts\\smoke.bat)",
      "Bash(scripts\\run_app.bat)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "scripts\\verify.bat && scripts\\smoke.bat || (echo VALIDATION FAILED - DO NOT STOP && exit 1)"
          }
        ]
      }
    ]
  }
}
