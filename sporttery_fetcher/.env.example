# HTTP 请求超时（秒）
REQUEST_TIMEOUT=15
# 重试次数
REQUEST_RETRIES=3
# 重试间隔（秒）
RETRY_WAIT_SECONDS=1
# User-Agent
USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0 Safari/537.36
# 是否保存 HTML 快照
SAVE_HTML_SNAPSHOT=true
# Playwright 无头模式
PLAYWRIGHT_HEADLESS=true

# Gemini 配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_THINKING_LEVEL=high
